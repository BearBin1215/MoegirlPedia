{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react",
    "module": "ESNext",
    "rootDir": "./",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noImplicitAny": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "oojs-ui-react": [
        "./src/components/oojs-ui-react"
      ]
    },
    "allowJs": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "exclude": [
    "dist",
  ],
  "include": [
    "src/**/*",
    "node_modules/moment/index.d.ts",
    "node_modules/types-mediawiki",
    "node_modules/@types/oojs-ui",
    "scripts/**/*",
    "eslint.config.js",
    "rspack.config.js",
    "stylelint.config.ts",
  ]
}
